# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=your-domain.railway.app,www.your-domain.railway.app

# Database (Railway will provide this)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# CORS Settings
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-domain.railway.app,https://www.your-domain.railway.app

# Optional: Add your own domain after deployment
# ALLOWED_HOSTS=your-domain.railway.app,yourdomain.com,www.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://your-domain.railway.app,https://yourdomain.com,https://www.yourdomain.com
